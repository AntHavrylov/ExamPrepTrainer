APP_NAME=Exam Prep Trainer
ENVIRONMENT=development

DATABASE_URL=sqlite:///./prep.db
SECRET_KEY=change-me-to-a-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
API_KEY_ENCRYPTION_KEY=change-me-to-a-generated-fernet-key

MAX_DOCUMENT_CONTENT_LENGTH=50000
MAX_SECTIONS_PER_USER=50

MAX_QUESTIONS_PER_GENERATE=20
MAX_GENERATION_CONTEXT_CHARS=12000

# Whether training sessions may trigger AI generation themselves. Off by default
# so generation only ever happens explicitly from the Question Bank tab.
LIVE_QUESTION_GENERATION_ENABLED=false

AI_RATE_LIMIT_MAX_REQUESTS=30
AI_RATE_LIMIT_WINDOW_SECONDS=60
